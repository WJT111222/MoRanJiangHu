# Copy to .env.production for local production builds.
# Do not commit .env.production. Values with VITE_ are embedded into frontend assets.

# Legacy compatibility only. Most model/API settings are configured in the app UI.
GEMINI_API_KEY=

# Frontend public build-time variables.
VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_NATIVE_CLIENT_ID=
VITE_SYNC_API_BASE_URL=https://msjh.bacon159.pp.ua

# Cloudflare Worker runtime secrets.
# Use these with: npm run cf:secrets:bulk -- .env.production
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_NATIVE_CLIENT_ID=
GITHUB_NATIVE_CLIENT_SECRET=
FANDOM_PRESET_GITHUB_TOKEN=
IMAGE_HOST_TOKEN=

# Cloudflare Worker runtime vars. These are not secrets and may also live in wrangler.jsonc.
FANDOM_PRESET_REPO_OWNER=
FANDOM_PRESET_REPO_NAME=
FANDOM_PRESET_BASE_BRANCH=main
