{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moranjianghu",
  "main": ".tmp-worker-build/index.js",
  "compatibility_date": "2026-04-21",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "msjh.bacon159.pp.ua/*",
      "zone_name": "bacon159.pp.ua"
    },
    {
      "pattern": "msjh.bacon.de5.net/*",
      "zone_name": "bacon.de5.net"
    }
  ],
  "vars": {
    "CNB_SYNC_R2_KEY": "moranjianghu/cnb-sync-registry.json"
  },
  "r2_buckets": [
    {
      "binding": "CNB_SYNC_R2",
      "bucket_name": "quark-downloads-bacon"
    }
  ],
  "observability": {
    "enabled": true
  }
}
